{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": { "Microsoft": "Warning" }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "HiTradeConnection": ""
  },
  "JWTOptions": {
    "Secret": "",
    "Issuer": "",
    "Audience": "",
    "ExpirationMinutes": 0
  },
  "FinnhubToken": "",
  "Redis": {
    "EndpointUrl": "",
    "EndpointPort": "",
    "User": "",
    "Password": ""
  }
}
